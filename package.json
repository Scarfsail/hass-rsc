{
  "name": "hass-rsc-release",
  "private": true,
  "version": "0.0.0-managed-by-semantic-release",
  "devDependencies": {
    "semantic-release": "^25.0.2",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      ["@semantic-release/commit-analyzer", { "preset": "angular" }],
      "@semantic-release/release-notes-generator",
      ["@semantic-release/exec", {
        "prepareCmd": "python -c \"import json; p='custom_components/rsc/manifest.json'; d=json.load(open(p)); d['version']='${nextRelease.version}'; f=open(p,'w'); json.dump(d, f, indent=2); f.write('\\n'); f.close()\""
      }],
      ["@semantic-release/git", {
        "assets": ["custom_components/rsc/manifest.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }],
      "@semantic-release/github"
    ]
  }
}
